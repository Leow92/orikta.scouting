# API-football (required)
# Get your key at https://www.api-football.com/
API_FOOTBALL_KEY=

# LLM provider — set LLM_PROVIDER to "mistral" (default) or "groq"
LLM_PROVIDER=mistral

# Mistral API key (required when LLM_PROVIDER=mistral)
# https://console.mistral.ai/
MISTRAL_API_KEY=

# Groq API key (required when LLM_PROVIDER=groq)
# https://console.groq.com/
GROQ_API_KEY=

# Optional: override default model names
# MISTRAL_NARRATIVE_MODEL=mistral-medium-3-5
# MISTRAL_ROUTER_MODEL=ministral-14b-2512
# GROQ_NARRATIVE_MODEL=openai/gpt-oss-120b
# GROQ_ROUTER_MODEL=llama-3.3-70b-versatile

# Internal / optional
VIBE=
